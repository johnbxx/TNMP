{
  "name": "tnmp",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:engine && vite build",
    "build:only": "vite build",
    "build:engine": "node scripts/build-engine.js",
    "build:eco": "node scripts/build-eco.js",
    "build:embed": "node scripts/build-embed-pieces.js && vite build --config vite.config.embed.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "lint": "oxlint src/",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "vite": "^8.0.3",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vitest": "^4.1.3",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@lichess-org/chessground": "^10.1.1",
    "@lichess-org/stockfish-web": "^0.2.3",
    "chess.js": "^1.4.0"
  }
}
